{
  "name": "bar3-server",
  "version": "1.1.1",
  "description": "The local server for Bar 3",
  "main": "./build/src/index.js",
  "bin": "./build/src/index.js",
  "scripts": {
    "start": "node ./build/src/index.js",
    "dev": "nodemon ./build/src/index.js --debug",
    "verbose": "node ./build/src/index.js --debug",
    "prebuild": "shx rm -rf ./build/*",
    "build": "tsc",
    "pack": "npm run build && pkg . --target node12-win-x86,node12-linux,node12-macos-x64",
    "postpack": "shx mkdir -p dist && shx mv bar3-server-* dist/",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "bsnk-dev",
  "license": "MIT",
  "dependencies": {
    "@types/cors": "^2.8.9",
    "@types/express": "^4.17.11",
    "@types/express-session": "^1.18.2",
    "@types/nedb": "^1.8.11",
    "@types/superagent": "^4.1.10",
    "@types/yargs": "^16.0.0",
    "@typescript-eslint/eslint-plugin": "^4.14.1",
    "@typescript-eslint/parser": "^4.13.0",
    "celebrate": "^14.0.0",
    "chalk": "^4.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "eslint": "^7.17.0",
    "eslint-config-google": "^0.14.0",
    "express": "^4.17.1",
    "express-session": "^1.19.0",
    "juice": "^11.1.1",
    "mongodb": "3.7.0",
    "mongoose": "^6.10.0",
    "nedb": "^1.8.0",
    "nodemon": "^2.0.7",
    "node-html-parser": "^3.3.5",
    "open": "^7.3.1",
    "pkg": "^4.4.9",
    "shx": "^0.3.3",
    "superagent": "^6.1.0",
    "typescript": "^4.1.3",
    "yargs": "^16.2.0"
  },
  "pkg": {
    "assets": [
      "./public/**/*",
      "./package.json"
    ]
  }
}
