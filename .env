MONGODB_URI=mongodb+srv://glaernischgaming_db_user:64WKiJPOcvufLvWP@glaernisch.0o1fjdx.mongodb.net/?appName=Glaernisch
PORT=3000

# Discord OAuth2 — create an app at https://discord.com/developers/applications
# and add the redirect URI below to the OAuth2 Redirects list.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# flame_bot HTTP API — used to verify bar3_server role after Discord login.
# Set FLAME_BOT_API_URL to the base URL of the running flame_bot instance and
# FLAME_BOT_API_KEY to the same value as flame_bot's API_KEY env var.
FLAME_BOT_API_URL=http://localhost:8080
FLAME_BOT_API_KEY=

# Random secret used to sign the session cookie — set a long random string in production
SESSION_SECRET=bar3-change-me-in-production

# CORS allowed origins — comma-separated list of frontend origins that are
# permitted to make credentialled cross-origin requests to this server.
# Example: CLIENT_ORIGIN=https://bar3-client.onrender.com
# In development this can be left empty (falls back to wildcard *).
CLIENT_ORIGIN=
