MONGODB_URI=mongodb+srv://glaernischgaming_db_user:64WKiJPOcvufLvWP@glaernisch.0o1fjdx.mongodb.net/?appName=Glaernisch
PORT=3000

# Discord OAuth2 — create an app at https://discord.com/developers/applications
# and add the redirect URI below to the OAuth2 Redirects list.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Discord bot token — found on the Bot tab of your application in the Discord Developer Portal.
# Used to look up guild member roles after the user logs in via OAuth2.
DISCORD_BOT_TOKEN=

# ID of the Discord guild (server) to check membership in.
# Enable Developer Mode in Discord, then right-click the server and copy its ID.
DISCORD_GUILD_ID=

# Discord role IDs that grant access.
# BAR3_CLIENT_ROLE_ID — role that grants normal client access (e.g. "member").
# BAR3_SERVER_ROLE_ID — (optional) role that grants server access.
# Enable Developer Mode, right-click the role under Server Settings → Roles, copy ID.
BAR3_CLIENT_ROLE_ID=
BAR3_SERVER_ROLE_ID=

# Random secret used to sign the session cookie — set a long random string in production
SESSION_SECRET=bar3-change-me-in-production

# URL of the bar3-client SPA.  After a successful Discord OAuth2 login the
# browser is redirected here so the SPA can take over routing.
# This origin is also automatically added to the CORS allow-list so the SPA
# can make credentialled cross-origin requests (e.g. /auth/session).
# Example: CLIENT_APP_URL=https://bar3-client.onrender.com
# Leave empty to fall back to a same-server relative-path redirect.
CLIENT_APP_URL=

# CORS allowed origins — optional, comma-separated additional frontend origins
# permitted to make credentialled cross-origin requests to this server.
# CLIENT_APP_URL is always included automatically; you only need this if you
# have additional origins beyond CLIENT_APP_URL.
# Example: CLIENT_ORIGIN=https://staging.bar3-client.onrender.com
# In development this can be left empty (falls back to wildcard *).
CLIENT_ORIGIN=
